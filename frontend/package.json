{
  "name": "frontend-svelte",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "bun run copy-version && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "sync-keys": " bun extract-i18n-keys.js",
    "copy-version": "cp ../VERSION ./static/VERSION 2>/dev/null || cp VERSION ./static/VERSION 2>/dev/null || echo 'VERSION file not found'",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.5.1",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "prettier": "^3.8.2",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "daisyui": "^5.5.19",
    "lucide-svelte": "^0.577.0",
    "qrcode": "^1.5.4"
  }
}
